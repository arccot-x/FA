generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncomeSourceType {
  DEFAULT
  VARIABLE_EXPECTED
  ADJUSTMENT
}

enum BillStatus {
  UNPAID
  PAID
  SKIPPED
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
}

enum TransactionStatus {
  CLEARED
  PENDING_DETAILS
}

enum TransactionSource {
  MANUAL
  SNAP_SAVE
  IMPORT
}

enum ExpenseCategory {
  GROCERIES
  DINING
  GAS
  TRANSPORT
  SHOPPING
  ENTERTAINMENT
  HEALTH
  HOME
  UTILITIES
  TRAVEL
  SUBSCRIPTION
  OTHER
}

enum VaultCategory {
  LEASE
  TAX
  INSURANCE
  RECEIPT
  BANKING
  MEDICAL
  WARRANTY
  OTHER
}

enum AttachmentOwnerType {
  TRANSACTION
  VAULT_DOCUMENT
}

enum DocumentMimeGroup {
  IMAGE
  PDF
  OTHER
}

enum FamilyRole {
  OWNER
  MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
}

enum TransactionScope {
  PERSONAL
  HOUSE
}

enum SubscriptionPlan {
  INDIVIDUAL
  FAMILY_3
  FAMILY_6
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  name                  String
  phoneNumber           String?
  avatarUrl             String?
  householdRole         String?
  passwordHash          String?
  defaultMonthlyIncome  Decimal            @default(0) @db.Decimal(12, 2)
  paydayDay             Int                @default(1)
  variableIncomeEnabled Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  incomeCycles          IncomeCycle[]
  billTemplates         BillTemplate[]
  billOccurrences       BillOccurrence[]
  transactions          Transaction[]
  attachments           Attachment[]
  vaultDocuments        VaultDocument[]
  passwordResetTokens   PasswordResetToken[]
  subscription          Subscription?
}

model Subscription {
  id          String           @id @default(cuid())
  userId      String           @unique
  plan        SubscriptionPlan @default(INDIVIDUAL)
  active      Boolean          @default(false)
  billingName String?
  billingEmail String?
  cardLast4   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan, active])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model IncomeCycle {
  id         String           @id @default(cuid())
  userId     String
  cycleMonth DateTime
  sourceType IncomeSourceType @default(DEFAULT)
  expected   Decimal          @db.Decimal(12, 2)
  actual     Decimal?         @db.Decimal(12, 2)
  houseAllocation Decimal?    @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cycleMonth])
  @@index([userId, cycleMonth])
}

model BillTemplate {
  id            String           @id @default(cuid())
  userId        String
  name          String
  category      ExpenseCategory  @default(OTHER)
  defaultAmount Decimal          @db.Decimal(12, 2)
  dueDay        Int
  icon          String           @default("receipt")
  autopay       Boolean          @default(false)
  active        Boolean          @default(true)
  scope         TransactionScope @default(PERSONAL)
  familyId      String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  occurrences   BillOccurrence[]

  @@index([userId, active, dueDay])
  @@index([familyId, scope])
}

model BillOccurrence {
  id             String        @id @default(cuid())
  userId         String
  billTemplateId String
  cycleMonth     DateTime
  dueDate        DateTime
  amount         Decimal       @db.Decimal(12, 2)
  status         BillStatus    @default(UNPAID)
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  billTemplate   BillTemplate  @relation(fields: [billTemplateId], references: [id], onDelete: Cascade)

  @@unique([billTemplateId, cycleMonth])
  @@index([userId, cycleMonth, status, dueDate])
}

model Transaction {
  id          String             @id @default(cuid())
  userId      String
  type        TransactionType    @default(EXPENSE)
  status      TransactionStatus  @default(CLEARED)
  source      TransactionSource  @default(MANUAL)
  amount      Decimal?           @db.Decimal(12, 2)
  category    ExpenseCategory?
  merchant    String?
  notes       String?
  aiScannedAt DateTime?
  scope       TransactionScope   @default(PERSONAL)
  familyId    String?
  occurredAt  DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([userId, occurredAt])
  @@index([userId, status])
  @@index([familyId, scope, occurredAt])
}

model Attachment {
  id              String               @id @default(cuid())
  userId          String
  ownerType       AttachmentOwnerType
  transactionId   String?
  vaultDocumentId String?
  fileName        String
  mimeType        String
  mimeGroup       DocumentMimeGroup    @default(OTHER)
  fileSize        Int
  url             String
  storagePath     String
  createdAt       DateTime             @default(now())
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction     Transaction?         @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  vaultDocument   VaultDocument?       @relation(fields: [vaultDocumentId], references: [id], onDelete: Cascade)

  @@index([userId, ownerType])
}

model VaultDocument {
  id          String            @id @default(cuid())
  userId      String
  title       String
  category    VaultCategory     @default(OTHER)
  mimeGroup   DocumentMimeGroup @default(OTHER)
  fileName    String
  mimeType    String
  fileSize    Int
  url         String
  storagePath String
  notes       String?
  issuedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([userId, category, createdAt])
}

model Family {
  id        String         @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  members   FamilyMember[]

  @@index([ownerId])
}

model FamilyMember {
  id        String       @id @default(cuid())
  familyId  String
  userId    String
  role      FamilyRole   @default(MEMBER)
  status    MemberStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  family    Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([userId, status])
}
