{
  "expo": {
    "name": "Frictionless Finance",
    "slug": "frictionless-finance",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "frictionlessfinance",
    "android": {
      "package": "com.frictionless.finance",
      "adaptiveIcon": {
        "backgroundColor": "#0E7C66"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#F7F8FA",
      "barStyle": "dark-content"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Frictionless Finance to capture receipts for Snap & Save."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "https://fa-8ttn.onrender.com/api"
    }
  }
}
